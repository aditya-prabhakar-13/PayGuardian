{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2017",
    "noImplicitAny": true,
    "strict": true,
    "outDir": "dist",
    "rootDir": "src",
    "declarationDir": "dist",
    "moduleResolution": "node",
    "declaration": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "lib": ["DOM", "ES2017"],
    "esModuleInterop": true
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
